# Test stage
FROM node:18-alpine

WORKDIR /app

# Install dependencies (including dev dependencies for testing)
COPY package*.json ./
RUN npm ci

# Copy source files
COPY . .

# Set environment variables for testing
ENV NODE_ENV=test
ENV CI=true

# Install testing tools globally
RUN npm install -g jest @testing-library/react @testing-library/jest-dom

# Expose port for test server
EXPOSE 5173

# Default command runs tests
CMD ["npm", "run", "test"]
